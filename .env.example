# ============================================
# 环境变量配置示例文件
# 复制此文件为 .env 或 .env.production 并填入实际值
# ============================================

# ============================================
# Supabase 配置（Guestbook + Auth）
# ============================================
# 前端客户端使用（带 NEXT_PUBLIC_ 前缀）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# 服务端专用（不带前缀，优先使用）
SUPABASE_URL=https://your-project.supabase.co
# 服务端密钥（仅后端使用）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Drizzle ORM 数据库连接
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project.supabase.co:5432/postgres

# ============================================
# Better Auth 配置
# ============================================
BETTER_AUTH_URL=http://localhost:3000

# ============================================
# GitHub OAuth 配置（用于用户登录，可选）
# ============================================
# 注意：使用 AUTH_GITHUB_ 前缀避免与 GitHub Actions 的系统变量冲突
# 如果不需要 GitHub 登录功能，可以留空
AUTH_GITHUB_CLIENT_ID=
AUTH_GITHUB_CLIENT_SECRET=

# ============================================
# GitHub App 配置（用于访问私有仓库）
# ============================================
APP_ID=
APP_PEM_KEY_BASE64=
APP_INSTALLATION_ID=

# ============================================
# SMTP 邮件配置（联系表单）
# ============================================
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=

# ============================================
# Dev.to API 配置
# ============================================
DEVTO_KEY=

# ============================================
# Spotify API 配置
# ============================================
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# ============================================
# Wakatime API 配置
# ============================================
WAKATIME_API_KEY=

# ============================================
# Blog API 配置
# ============================================
BLOG_API_URL=
