#!/bin/sh
# ============================================
# Git Pre-Commit Hook
# ============================================
# 功能：提交前执行轻量级代码质量检查
# 注意：完整的检查（包括 build）在 pre-push 时执行
# ============================================

echo "🔍 运行代码质量检查..."

# Lint 检查
bun run app:lint || exit 1

# TypeScript 类型检查
cd apps/app && bunx tsc --noEmit || exit 1

echo "✅ 代码质量检查通过"
