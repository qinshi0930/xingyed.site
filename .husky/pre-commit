#!/bin/sh
# ============================================
# Git Pre-Commit Hook
# ============================================
# 功能：提交前执行轻量级代码质量检查
# 策略：使用 lint-staged 只检查修改的文件（快速）
# 完整检查（build、测试）在 pre-push 时执行
# ============================================

# 确保 Bun 工具链可用
export PATH="$HOME/.bun/bin:$PATH"

echo "🔍 运行代码质量检查（增量）..."
echo ""

# 使用 lint-staged 只检查暂存的文件
bunx lint-staged --quiet || exit 1

echo ""
echo "✅ 代码质量检查通过"
