#!/bin/bash
# ============================================
# Git Pre-Push Hook
# ============================================
# 功能：推送前验证
# 说明：
#   代码质量检查已在 pre-commit 时完成
#   此 hook 仅做推送验证（删除分支确认等）
# ============================================

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m' # No Color

echo -e "${BLUE}${BOLD}"
echo "========================================="
echo "  Git Pre-Push Hook - 推送验证"
echo "========================================="
echo -e "${NC}"

# 获取推送信息
read -r local_ref local_sha remote_ref remote_sha

# 判断是否为删除操作
if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
    echo -e "${YELLOW}⚠️  删除分支/标签操作${NC}"
    echo -e "${BLUE}   本地引用: $local_ref${NC}"
    echo -e "${BLUE}   远程引用: $remote_ref${NC}"
    exit 0
fi

echo -e "${GREEN}✅ 推送验证通过${NC}"
echo -e "${BLUE}   本地分支: $local_ref${NC}"
echo -e "${BLUE}   远程分支: $remote_ref${NC}"
echo -e "${GREEN}   代码质量检查已在 commit 时完成${NC}"
echo ""
