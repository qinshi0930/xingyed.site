9-13","is_playground":true,"is_comment":false},"content":"$1b"},{"slug":"4-types","frontMatter":{"id":4,"chapter_id":1,"chapter_title":"Chapter 1 : Basics","title":"Types","category":"JavaScript Fundamental","language":"JavaScript","difficulty":"Easy","source":null,"cover_url":"/images/learn/javascript.svg","source_url":null,"created_at":"2023-09-14","updated_at":"2023-09-14","is_playground":false,"is_comment":false},"content":"$1c"},{"slug":"5-typeof","frontMatter":{"id":5,"chapter_id":1,"chapter_title":"Chapter 1 : Basics","title":"Type of","category":"JavaScript Fundamental","language":"JavaScript","difficulty":"Easy","source":null,"cover_url":"/images/learn/javascript.svg","source_url":null,"created_at":"2023-09-14","updated_at":"2023-09-14","is_playground":false,"is_comment":false},"content":"$1d"},{"slug":"6-equality","frontMatter":{"id":6,"chapter_id":1,"chapter_title":"Chapter 1 : Basics","title":"Equality","category":"JavaScript Fundamental","language":"JavaScript","difficulty":"Easy","source":null,"cover_url":"/images/learn/javascript.svg","source_url":null,"created_at":"2023-09-15","updated_at":"2023-09-15","is_playground":true,"is_comment":false},"content":"$1e"},{"slug":"7-numbers","frontMatter":{"id":7,"chapter_id":2,"chapter_title":"Chapter 2 : Numbers","title":"Numbers","category":"JavaScript Fundamental","language":"JavaScript","difficulty":"Easy","source":null,"cover_url":"/images/learn/javascript.svg","source_url":null,"created_at":"2023-09-15","updated_at":"2023-09-15","is_playground":true,"is_comment":false},"content":"In JavaScript, there's just **one type of number** – a 64-bit floating-point value. This aligns with Java's `double`. Unlike some other programming languages, **JavaScript doesn't have a separate integer type**. So, both 1 and 1.0 represent the same value.\n\nCreating a number is straightforward, similar to any other variable type. Just use the `var`, `let` or `const` keyword.\n\nYou can define numbers using constant values:\n\n```\n// This is a float:\nlet a = 3.5;\n\n// This is an integer:\nlet b = 20;\n```\n\nAlternatively, you can derive a number from the value of another variable:\n\n```\nlet a = 4;\nlet b = a;\n```\n\nIn JavaScript, integers maintain precision up to 15 digits, with the maximum number being 17.\n\n```\nlet a = 123456789012345;   // m will be 123456789012345\nlet b = 12345678901234567;  // n will be 12345678901234567\n```\n\nNumeric constants are recognized as hexadecimal if they are preceded by 0x.\n\n```\nlet a = 0xAA; // This evaluates to 170\n```\n"},{"slug":"8-basic-operator","frontMatter":{"id":8,"chapter_id":2,"chapter_title":"Chapter 2 : Numbers","title":"Basic Operator","category":"JavaScript Fundamental","language":"JavaScript","difficulty":"Easy","source":null,"cover_url":"/images/learn/javascript.svg","source_url":null,"created_at":"2023-09-16","updated_at":"2023-09-16","is_playground":true,"is_comment":false},"content":"$1f"},{"slug":"9-math","frontMatter":{"id":9,"chapter_id":2,"chapter_title":"Chapter 2 : Numbers","title":"Math","category":"JavaScript Fundamental","language":"JavaScript","difficulty":"Easy","source":null,"cover_url":"/images/learn/javascript.svg","source_url":null,"created_at":"2023-09-17","updated_at":"2023-09-17","is_playground":true,"is_comment":false},"content":"$20"},{"slug":"10-advanced-operator","frontMatter":{"id":10,"chapter_id":2,"chapter_title":"Chapter 2 : Numbers","title":"Advanced Operator","category":"JavaScript Fundamental","language":"JavaScript","difficulty":"Easy","source":null,"cover_url":"/images/learn/javascript.svg","source_url":null,"created_at":"2023-09-18","updated_at":"2023-09-18","is_playground":true,"is_comment":false},"content":"$21"}],"content":{"id":1,"title":"JavasScript Fundamental","slug":"js-fundamental","description":"Master the fundamentals of programming in JavaScript.","image":"/images/learn/javascript.svg","is_new":true,"level":"Beginner","is_show":true},"title":"JavasScript Fundamental"}]]}]
